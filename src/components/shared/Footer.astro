---
import Container from '../shared/Container.astro';
import Logo from '../shared/Logo.astro';
import Icon from '../shared/Icon.astro';
---

<footer class="border-t border-slate-200 dark:border-slate-800 bg-background-light dark:bg-background-dark py-12">
  <Container size="xl">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-12">
      <!-- Colonne gauche (2/3) -->
      <div class="md:col-span-2">
        <div class="flex items-center gap-3 text-slate-900 dark:text-slate-100 mb-6">
          <Logo size="sm" />
          <span class="font-bold uppercase tracking-tight">Atelier d’Arthémis</span>
        </div>
        <p class="text-slate-600 dark:text-slate-300 text-sm font-light leading-relaxed">
          Des bijoux faits main. Bracelets, boucles d’oreilles et colliers personnalisables. Des créations aux touches de couleurs, pensées pour s’accorder avec toutes vos tenues. À votre écoute pour donner vie à des pièces uniques, à votre image.
        </p>
      </div>

      <!-- Colonne droite (1/3) -->
      <div class="flex md:justify-end items-center mt-6 md:mt-0">
        <p class="text-slate-600 dark:text-slate-500 text-[10px] uppercase tracking-widest font-medium text-right">
          © All Rights Reserved.
        </p>
      </div>
    </div>
  </Container>
</footer>